generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Participant {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  firstName       String
  lastName        String
  institute       String
  course          String
  phoneNumber     String
  passTier        PassTier
  eventsApplied   String[]  @default([])
  billingAmount   Float
  isVerified      Boolean   @default(false)
  paymentSSLink   String
}

enum Year {
  First
  Second
  Third
  Fourth
}

enum PassTier {
  Premium
  Customized
}

model Admin{
  id             Int @id @default(autoincrement())
  email          String @unique
  hashedPassword String 
  permisssions   Permission[] @default([VIEW])
}

enum Permission{
  VIEW
  MODIFY
}